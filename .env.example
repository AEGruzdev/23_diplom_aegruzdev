
@"
# Django settings
# Сгенерируйте свой секретный ключ: https://djecrety.ir/
SECRET_KEY=your-secret-key-here-change-it-in-production
DEBUG=True

# Database settings for PostgreSQL
DB_NAME=diplom_db
DB_USER=diplom_user
DB_PASSWORD=your_secure_password
DB_HOST=localhost
DB_PORT=5432

# Email settings for Gmail (раскомментируйте и настройте при необходимости)
# EMAIL_HOST=smtp.gmail.com
# EMAIL_PORT=587
# EMAIL_USE_TLS=True
# EMAIL_HOST_USER=your-email@gmail.com
# EMAIL_HOST_PASSWORD=your-app-password

# Для разработки можно использовать консольный вывод email
# EMAIL_BACKEND=django.core.mail.backends.console.EmailBackend
"@ | Out-File -FilePath .env.example -Encoding UTF8